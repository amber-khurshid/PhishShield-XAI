{
  "buildCommand": "cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "env": {
    "MODEL_DIR": "./models/classical_model",
    "PYTHONPATH": "."
  },
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "memory": 2048,
      "maxDuration": 60,
      "includeFiles": "models/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    }
  ]
}
